# Database
POSTGRES_USER=business_admin
POSTGRES_PASSWORD=business_pass
POSTGRES_DB=business_db
DATABASE_URL=postgresql://business_admin:business_pass@localhost:5432/business_db

# LLM Configuration
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4o

# Retrieval Agent LLM
RETRIEVAL_LLM_API_KEY=your-google-api-key-here
RETRIEVAL_LLM_MODEL=gemini-2.0-flash

# Redis (Short-Term Memory / Cache)
REDIS_URL=redis://localhost:6379/0

# Application
LOG_LEVEL=INFO
APP_ENV=development
