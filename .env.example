# Database
POSTGRES_USER=business_admin
POSTGRES_PASSWORD=business_pass
POSTGRES_DB=business_db
DATABASE_URL=postgresql+psycopg2://business_admin:business_pass@localhost:5432/business_db

# LLM Provider
AI_PROVIDER=auto
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# Retrieval Agent LLM (optional override, default as auto)
RETRIEVAL_LLM_PROVIDER=
RETRIEVAL_LLM_API_KEY=
RETRIEVAL_LLM_MODEL=

# External Research
TAVILY_API_KEY=your-tavily-api-key-here

# Redis (Short-Term Memory / Cache)
REDIS_URL=redis://localhost:6379/0

# Application
LOG_LEVEL=INFO
APP_ENV=development
