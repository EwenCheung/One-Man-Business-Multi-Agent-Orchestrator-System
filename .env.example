# ─── Database (Supabase — unified) ────────────────────────────────
# Get this from Supabase Dashboard → Settings → Database → Connection string (URI)
SUPABASE_DB_URL=postgresql://postgres.[your-project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres

NEXT_PUBLIC_SUPABASE_URL=https://mgxjyaflnkapukvaywvj.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-supabase-publishable-key-here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key-here

SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
# ─── LLM Provider ─────────────────────────────────────────────────
AI_PROVIDER=auto
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# ─── Retrieval Agent LLM (optional override) ──────────────────────
RETRIEVAL_LLM_PROVIDER=
RETRIEVAL_LLM_API_KEY=
RETRIEVAL_LLM_MODEL=

# ─── Policy Agent LLM (optional override) ──────────────────────
POLICY_LLM_PROVIDER=
POLICY_LLM_API_KEY=
POLICY_LLM_MODEL=

# ─── RAG / Embeddings ─────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
HF_TOKEN=your-huggingface-api-key-here

# ─── External Research ────────────────────────────────────────────
TAVILY_API_KEY=your-tavily-api-key-here

# ─── Redis (Short-Term Memory / Cache) ────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Application ──────────────────────────────────────────────────
LOG_LEVEL=INFO
APP_ENV=development
MAX_REPLAN_CYCLES=2
MAX_PARALLEL_TASKS=4

# ─── Langfuse ──────────────────────────────────────────────────
LANGFUSE_SECRET_KEY=your-langfuse-secret-key-here
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key-here
LANGFUSE_HOST=https://cloud.langfuse.com

# Backend
BACKEND_PUBLIC_URL=https://7885-137-132-26-112.ngrok-free.app